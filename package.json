{
  "name": "solana-wallet-advanced",
  "version": "1.1.0",
  "description": "Advanced Solana Wallet with MEV Protection - Production-ready multi-platform DeFi wallet with modern UI, comprehensive API integration, and enterprise-grade security",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/SMSDAO/solana-defi-wallet.git"
  },
  "keywords": [
    "solana",
    "wallet",
    "defi",
    "crypto",
    "blockchain",
    "mev-protection",
    "swap",
    "trading",
    "nextjs",
    "typescript",
    "web3"
  ],
  "author": "SMSDAO",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:light": "NODE_ENV=production next build",
    "start": "next start",
    "clean": "rm -rf .next node_modules",
    "install:light": "npm install --no-optional --legacy-peer-deps --prefer-offline",
    "postinstall": "npx prisma generate || echo 'Prisma generate skipped'",
    "vercel-build": "npx prisma generate && next build",
    "prebuild": "npx prisma generate || echo 'Prisma generate skipped'",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@prisma/client": "^5.0.0",
    "@solana/spl-token": "^0.3.9",
    "@solana/wallet-adapter-base": "^0.9.23",
    "@solana/wallet-adapter-react": "^0.15.35",
    "@solana/wallet-adapter-react-ui": "^0.9.35",
    "@solana/wallet-adapter-wallets": "^0.19.32",
    "@solana/web3.js": "^1.87.6",
    "autoprefixer": "^10.4.16",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.0.0",
    "critters": "^0.0.23",
    "framer-motion": "^10.16.16",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.303.0",
    "next": "^14.0.4",
    "postcss": "^8.4.33",
    "prisma": "^5.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "tailwind-merge": "^2.2.0",
    "tailwindcss": "^3.4.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.0.4",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0"
  },
  "bundleDependencies": []
}
